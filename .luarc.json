{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "?.lua",
      "?/init.lua"
    ]
  },
  "workspace": {
    "checkThirdParty": false,
    "ignoreDir": [
      "lua/metabuffer/nfnl",
      ".rocks",
      "deps"
    ]
  },
  "diagnostics": {
    "globals": [
      "vim"
    ]
  },
  "telemetry": {
    "enable": false
  }
}
