{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "Lua": {
    "runtime": {
      "version": "LuaJIT",
      "path": [
        "?.lua",
        "?/init.lua"
      ]
    },
    "workspace": {
      "checkThirdParty": false,
      "ignoreDir": [
        "metabuffer/nfnl",
        "lua/metabuffer/nfnl",
        ".rocks",
        "deps"
      ]
    },
    "diagnostics": {
      "globals": [
        "vim"
      ],
      "disable": [
        "duplicate-set-field"
      ]
    },
    "telemetry": {
      "enable": false
    }
  }
}
