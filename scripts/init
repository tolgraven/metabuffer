#!/usr/bin/env bash
# Initialize project dependencies for the Neovim runtime ABI.
# Rocks must target Lua 5.1/LuaJIT, not whichever standalone `lua` is on PATH.

test -x ./scripts/deps || { echo >&2 "scripts/deps is missing or not executable."; exit 1; }
./scripts/init-nfnl
./scripts/deps --lua-version 5.1 --show

patch -p1 < scripts/async.fnl.patch_lua51
